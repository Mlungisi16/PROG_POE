<Window x:Class="Cyber_Bot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cyber Bot"
        Height="800"
        Width="1200"
        Background="Black">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL -->
        <StackPanel Grid.Column="0" Margin="10">

            <TextBlock Text="CYBER BOT" Foreground="Lime" FontSize="22" Margin="5"/>

            <!-- TASK -->
            <TextBox x:Name="taskTitleBox" Margin="5" />
            <TextBox x:Name="taskDescBox" Margin="5" />
            <TextBox x:Name="taskReminderBox" Margin="5" />

            <Button Content="Add Task" Click="AddTask_Click"/>
            <Button Content="View Tasks" Click="ViewTasks_Click"/>
            <Button Content="Delete Task" Click="DeleteTask_Click"/>
            <Button Content="Complete Task" Click="CompleteTask_Click"/>

            <ListBox x:Name="taskList" Height="120" Margin="5"/>

            <!-- QUIZ -->
            <Button Content="Start Quiz" Click="StartQuiz_Click" Margin="5"/>
            <TextBlock x:Name="quizQuestionText" Foreground="White" Margin="5"/>

            <Button Content="A" Click="AnswerA_Click"/>
            <Button Content="B" Click="AnswerB_Click"/>
            <Button Content="C" Click="AnswerC_Click"/>
            <Button Content="True/False" Click="AnswerTF_Click"/>

            <!-- LOG -->
            <ListBox x:Name="activityLogBox" Height="120" Margin="5"/>
            <Button Content="Show Log" Click="ShowLog_Click"/>

        </StackPanel>

        <!-- CHAT -->
        <Grid Grid.Column="1">

            <RichTextBox x:Name="chatBox"
                         Background="Black"
                         Foreground="Lime"
                         FontSize="14"
                         IsReadOnly="True"
                         Margin="10"/>

            <TextBox x:Name="inputBox"
                     VerticalAlignment="Bottom"
                     Margin="10,0,120,10"/>

            <Button Content="Send"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Right"
                    Margin="0,0,10,10"
                    Width="100"
                    Click="SendButton_Click"/>

        </Grid>

    </Grid>
</Window>